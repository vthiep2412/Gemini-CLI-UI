{
  "name": "gemini-cli-ui",
  "version": "1.5.0",
  "description": "A stylish web-based UI for Gemini CLI",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently --kill-others \"bun run server:dev\" \"bun run client\"",
    "server": "bun server/index.js",
    "server:dev": "bun --watch server/index.js",
    "client": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bun run build && bun run server"
  },
  "keywords": [
    "gemini",
    "ai",
    "code",
    "ui",
    "assistant"
  ],
  "author": "Gemini CLI UI Contributors",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "bcrypt": "^6.0.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.515.0",
    "material-file-icons": "^2.4.0",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.4.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "react-syntax-highlighter": "^15.6.6",
    "react-window": "^2.2.7",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  },
  "overrides": {
    "dompurify": "^3.3.2",
    "prismjs": "^1.30.0"
  }
}
